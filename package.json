{
  "name": "expense-challenge",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack reference app for tracking USD purchases with multi-currency conversion via US Treasury Reporting Rates of Exchange.",
  "license": "MIT",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @expense-challenge/web dev",
    "dev:live": "pnpm --filter @expense-challenge/web dev:live",
    "backend": "cd backend && SPRING_PROFILES_ACTIVE=local ./gradlew bootRun",
    "test:backend": "cd backend && ./gradlew test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "generate": "turbo run generate",
    "clean": "turbo run clean && cd backend && ./gradlew clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml,scss}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml,scss}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
