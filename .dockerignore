# Keep build context small and reproducible
**/node_modules
**/.next
**/.turbo
**/coverage
**/playwright-report
**/test-results
**/dist
**/build
**/*.tsbuildinfo

# Local-only / IDE
.vscode/
.idea/
.DS_Store

# Interview materials never reach the public repo and never belong in
# any image
docs/

# Git metadata (the image does not need git history)
.git
.gitignore

# Logs
*.log
